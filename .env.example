# ═══════════════════════════════════════════════════════════════════════════════
#  RELCKO PROTOCOL — DEPLOYMENT ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════════════
#  Copy this to .env and fill in your values.
#    cp .env.example .env
#
#  Network is selected automatically based on --rpc-url.
#  Use separate .env files for testnet vs mainnet.
# ═══════════════════════════════════════════════════════════════════════════════

# ── RPC ──────────────────────────────────────────────────────────────────────
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545
BSC_MAINNET_RPC=https://bsc-dataseed.binance.org

# ── DEPLOYER ─────────────────────────────────────────────────────────────────
#  Private key of the deployer (used to broadcast and to derive the deployer
#  address for owner/treasury verification). Alternatively set DEPLOYER to the
#  explicit EOA address if the key is supplied via --private-key / LEDGER.
DEPLOYER_PK=your_private_key_here
# DEPLOYER=0xYourDeployerAddress

# ── TREASURY ─────────────────────────────────────────────────────────────────
#  Multisig address that receives PaymentManager ownership (Ownable2Step).
#  If set, deployer initiates transfer; treasury must call acceptOwnership().
TREASURY=0x0000000000000000000000000000000000000000

# ── RLKO TOKEN ───────────────────────────────────────────────────────────────
RLKO_NAME=Relcko Token
RLKO_SYMBOL=RLKO
RLKO_DECIMALS=18
RLKO_SUPPLY=1000000000000000000000000000        # 1 000 000 000 RLKO (18 decimals)

# ── PRESALE ──────────────────────────────────────────────────────────────────
PRESALE_SUPPLY=10000000000000000000000           # 10 000 RLKO

# ── STAGE 1 ──────────────────────────────────────────────────────────────────
STAGE1_PRICE=1150000000000000000                 # 1.15 USDT (18 decimals)
STAGE1_SUPPLY=10000000000000000000000            # 10 000 RLKO (18 decimals)
STAGE1_MIN_PER_USER=10000000000000000000         # 10 USDT (18 decimals)
STAGE1_MAX_PER_USER=100000000000000000000000     # 100 000 USDT (18 decimals)

# ── MOCK USDT (testnet only) ─────────────────────────────────────────────────
#  Set MOCK_USDT=true to deploy a fresh MockUSDT contract (no hardcoded address).
#  On testnet (chain 97) this defaults to true. When false or on mainnet,
#  USDT_TOKEN must point to an existing USDT contract.
MOCK_USDT=true
# USDT_TOKEN=0x0000000000000000000000000000000000000000
# USDT_TOKEN_TESTNET=0x0000000000000000000000000000000000000000
# USDT_TOKEN_MAINNET=0x0000000000000000000000000000000000000000

# ── CHAINLINK BNB/USD FEED ───────────────────────────────────────────────────
#  Set the feed address for your target network.
BNB_USD_FEED_TESTNET=0x2514895c72f50D8bd4B4F9b1110F0D6bD2c97526
BNB_USD_FEED_MAINNET=0x0567F2323251f0Aab15c8dFb1967E4e8A7D42aeE
# BNB_USD_FEED=0x0000000000000000000000000000000000000000

# ── DEPLOYED ADDRESSES (for configure/verify steps) ──────────────────────────
RLKO_ADDRESS=0x0000000000000000000000000000000000000000
PAYMENT_MANAGER=0x0000000000000000000000000000000000000000
